# ============================================================
# HD Platform
# EditorConfig
# https://editorconfig.org/
# ============================================================

root = true

# ============================================================
# Default
# ============================================================

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# ============================================================
# Java
# ============================================================

[*.java]
indent_size = 4
max_line_length = 120

# ============================================================
# Kotlin (Future)
# ============================================================

[*.{kt,kts}]
indent_size = 4
max_line_length = 120

# ============================================================
# XML
# ============================================================

[*.xml]
indent_size = 4

# ============================================================
# YAML
# ============================================================

[*.{yml,yaml}]
indent_size = 2

# ============================================================
# JSON
# ============================================================

[*.json]
indent_size = 2

# ============================================================
# Markdown
# ============================================================

[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ============================================================
# Properties
# ============================================================

[*.properties]
indent_size = 2

# ============================================================
# Shell
# ============================================================

[*.sh]
indent_size = 2

# ============================================================
# Docker
# ============================================================

[Dockerfile]
indent_size = 4

# ============================================================
# SQL
# ============================================================

[*.sql]
indent_size = 4

# ============================================================
# GitHub Actions
# ============================================================

[*.{yaml,yml}]
indent_size = 2